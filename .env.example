# All variables here are OPTIONAL and stdio-only.
# On Cloudflare Workers deployments env vars are ignored — each user
# configures their own credentials via the `configure` tool.
#
# The preferred stdio workflow is to call the `configure` tool from your
# MCP client, which persists credentials to ~/.mal-mcp-config.json. These
# env vars exist only as a convenience: if the config file is empty on
# startup, MAL_CLIENT_ID / MAL_CLIENT_SECRET are copied into it once.

# Create an API client at https://myanimelist.net/apiconfig
# Choose "App Type: other" and set an App Redirect URL of http://localhost:8765/callback
MAL_CLIENT_ID=

# Required only if your MAL app was issued a client secret
# (public/PKCE clients can leave this blank).
MAL_CLIENT_SECRET=

# Port for the local OAuth callback server used by the stdio `authenticate`
# tool and `bun run auth` CLI (default 8765). Must match the redirect URL
# registered on your MAL API client.
MAL_AUTH_PORT=8765
